<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ page session="false" %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ERE Account Transition</title>

    <style>
        :root {
            --page-bg: #f5f7fa;
            --panel-bg: #ffffff;
            --notice-bg: #e4f5f6;
            --notice-border: #4f9fa4;
            --notice-icon: #146da8;
            --text: #1f2933;
            --secondary-text: #374151;
            --primary: #1769aa;
            --primary-hover: #125887;
            --focus: #ffbf47;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, Helvetica, sans-serif;
            color: var(--text);
            background: var(--page-bg);
        }

        .page-wrapper {
            width: min(1120px, calc(100% - 32px));
            margin: 60px auto;
        }

        .transition-panel {
            padding: 22px;
            background: var(--panel-bg);
            border: 1px solid #d5dde4;
            border-radius: 6px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.14);
        }

        .notice-box {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            padding: 20px;
            background: var(--notice-bg);
            border: 2px solid var(--notice-border);
            border-radius: 8px;
        }

        .notice-icon {
            flex: 0 0 28px;
            width: 28px;
            height: 28px;
            display: grid;
            place-items: center;
            border-radius: 50%;
            color: #ffffff;
            background: var(--notice-icon);
            font-family: Georgia, serif;
            font-size: 20px;
            font-weight: bold;
            line-height: 1;
        }

        .notice-content h1 {
            margin: 0 0 12px;
            font-size: 18px;
            line-height: 1.45;
        }

        .notice-content p {
            margin: 0 0 12px;
            color: var(--secondary-text);
            font-size: 16px;
            line-height: 1.55;
        }

        .notice-content p:last-child {
            margin-bottom: 0;
        }

        .discontinue-text {
            font-style: italic;
        }

        .button-row {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 18px;
        }

        .action-button {
            min-height: 44px;
            padding: 10px 16px;
            border-radius: 5px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
        }

        .primary-button {
            color: #ffffff;
            background: var(--primary);
            border: 2px solid var(--primary);
        }

        .primary-button:hover {
            background: var(--primary-hover);
            border-color: var(--primary-hover);
        }

        .secondary-button {
            color: var(--primary);
            background: #ffffff;
            border: 2px solid var(--primary);
        }

        .tertiary-button {
            color: #27313a;
            background: #ffffff;
            border: 2px solid #687684;
        }

        .action-button:focus-visible {
            outline: 4px solid var(--focus);
            outline-offset: 3px;
        }

        @media (max-width: 720px) {
            .page-wrapper {
                margin: 24px auto;
            }

            .transition-panel {
                padding: 14px;
            }

            .notice-box {
                padding: 16px;
            }

            .button-row form,
            .action-button {
                width: 100%;
            }
        }
    </style>
</head>

<body>
<main class="page-wrapper">
    <section class="transition-panel" aria-labelledby="transition-title">

        <div class="notice-box">
            <div class="notice-icon" aria-hidden="true">i</div>

            <div class="notice-content">
                <h1 id="transition-title">
                    To enhance security and identity protection, we are transitioning
                    from ERE username accounts to Login.gov and ID.me.
                </h1>

                <p>
                    To ensure uninterrupted access to your ERE account, please create a
                    Login.gov or ID.me account, or sign in with your existing Login.gov
                    or ID.me account.
                </p>

                <p class="discontinue-text">
                    <strong>
                        If you choose to discontinue using ERE rather than transition
                        to the new sign-in method, please notify us at
                        “DA DillInnovation Digital Services ROME Account Transition.”
                    </strong>
                    For Login.gov or ID.me support, please contact the respective Help Center.
                </p>
            </div>
        </div>

        <div class="button-row">
            <form method="post" action="${pageContext.request.contextPath}/account-transition">
                <input type="hidden" name="action" value="loginGov">
                <button type="submit" class="action-button primary-button">
                    Create an Account or Sign In with Login.gov
                </button>
            </form>

            <form method="post" action="${pageContext.request.contextPath}/account-transition">
                <input type="hidden" name="action" value="idMe">
                <button type="submit" class="action-button secondary-button">
                    Create an Account or Sign In with ID.me
                </button>
            </form>

            <form method="post" action="${pageContext.request.contextPath}/account-transition">
                <input type="hidden" name="action" value="continue">
                <button type="submit" class="action-button tertiary-button">
                    Continue without Transitioning
                </button>
            </form>
        </div>

    </section>
</main>
</body>
</html>
